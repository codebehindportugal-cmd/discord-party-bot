# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
PREFIX=!
DEFAULT_LANGUAGE=pt
BOT_NAME=MordsFocas
BOT_LOGO_URL=https://your-domain.example/images/mordsfocas-logo.png

# Base de dados
DATABASE_URL="mysql://user:password@localhost:3306/partybot"

# API do site (para verificar subscrições)
SITE_API_URL=http://localhost:3000/api
SITE_API_KEY=dev_shared_api_key_change_me

# Plano máximo de jogadores por plano
FREE_MAX_PLAYERS=5
FREE_MAX_EVENTS=1
FREE_MAX_GAMES=1

PRO_MAX_PLAYERS=20
PRO_MAX_EVENTS=999
PRO_MAX_GAMES=2

# Tempo de tolerância para reconexão (minutos)
CRASH_TOLERANCE_MINUTES=5
